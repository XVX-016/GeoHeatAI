# Secrets — never commit
config/gee-service-account.json
config/drive_token.json
config/drive_oauth_client.json
*.json.key
.env

# Data
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Earth Engine local credential cache (if using interactive auth)
.config/earthengine/
